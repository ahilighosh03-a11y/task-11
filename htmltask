<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thala 7- Sneaker Selling Store</title>
    <link rel="stylesheet" href="11.css">
</head>
<body>
    <input type="radio" name="app-state" id="state-landing" class="page-state" checked>
    <input type="radio" name="app-state" id="state-product" class="page-state">
    <input type="radio" name="app-state" id="state-cart" class="page-state">
    <input type="radio" namr="app-state" id="state-payment" class="page-state">
    <header>
        <label for="state-landing" class="logo">Thala <span>7.</span></label>
        <nav>
            <label for="state-landing" class="nav-link">Home</label>
            <label for="state-landing" class="nav-link">About</label>
            <label for="state-landing" class="nav-links">Shop Now</label>
            <label for="state-landing" class="nav-links">More</label>
            <label for="state-landing" class="nav-links">Contact</label>
        </nav>
        <div class="nav-right">
            <input type="text" class="search-bar" placeholder="Search">
            <label for="state-cart" class="icon-btn">
                <span class="cart-badge">3</span>
            </label>
            <div class="profile-pic"></div>
        </div>
    </header>
    <div id="view-landing" class="view-container">
        <section class="hero-section">
            <div class="hero-left">
                <div class="hero-brand">SEVEN</div>
                <h1>7!! Thala For<br>a <span>Reason!</span></h1>
                <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit. Pariatur soluta possimus nam doloribus distinctio quis magni, cumque alias laboriosam praesentium.</p>
                <label for="state-product" class="btn-shop-now" >Shop Now</label>
            </div>
              <div class="hero-right">
                <img src="https://wwd.com/wp-content/uploads/2019/07/nike-air-max-1-og.jpg" alt="Thala 7 Sneaker">
              </div>
        </section>
        <div class="service-overview">
            <div class="service-item">
                <h3>2k+</h3>
                <p>Reviews</p>

            </div>
            <div class="service-item">
                <h3>30k+</h3>
                <p>Customers</p>
            </div>
            <div class="service-item">
                <h3>High</h3>
                <p>Quality</p>
            </div>
            <div class="service-item">
                <h3>4.5/5</h3>
                <p>Rating</p>
            </div>
        </div>
    </div>
    <div id="view-product" class="view-container">
        <div class="product-container">
            <div class="product-gallery">
                <img class="main-product-img" src="https://upload.wikimedia.org/wikipedia/commons/9/94/Nike_Cortez.jpg" alt="Main Product Shoe">
                <div class="scrolling-gallery">
                    <img src="https://cms-cdn.goat.com/750/e44216bea3fe-8ad8-de11-8126-055d71c2.jpg">
                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTuwyW_PakRNLDiWaVVezNAB-8Hwsju0kxwrOizWuiFlxorZqXaueDQf5g&s=10">
                    <img src="https://cdn.culture-circle.com/productsimages/product/1280/5390.png">
                    <img src="https://cdn-images.farfetch-contents.com/19/85/91/66/19859166_44483924_600.jpg">

                </div>

            </div>
            <div class="product-details">
                <h2>Seven By M.S.Dhoni <br> Women's Hogun Multi-Color Running Shoes</h2>
                <p class="desc">For exceptional fit,feel and smooth transitions get going with these dual mid sole technology shoes constructed with molded EVS sock liner,gel at heel area, rubber outsole, fused upper and breathable....</p>
                <div class="price-row">
                    <span class="current-price">₹1,334</span>
                    <span class="save-tag">Save 12%</span>
                    <span class="tax-info">Inclusive of all Taxes</span>
                </div>
                
                <div class="purchase-actions">
                    <select class="quantity-select">
                        <option>1</option>
                        <option selected>2</option>
                        <option>3</option>
                    </select>
                    <label for="state-cart" class="btn-add-cart">🛒 ADD TO CART</label>
                </div>
            
        
                
            </div>
        </div>
    </div>


    <div id="view-cart" class="view-container">
        <div class="cart-container">
            <div class="cart-left">
                <h2>Shopping Cart</h2>
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="cart-item-title">Seven By M.S.Dhoni W...</td>
                            <td>- 1 +</td>
                            <td>₹4,999</td>
                            <td><span class="remove-icon">×</span></td>
                        </tr>
                        <tr>
                            <td class="cart-item-title">Seven By M.S.Dhoni W...</td>
                            <td>- 1 +</td>
                            <td>₹4,999</td>
                            <td><span class="remove-icon">×</span></td>
                        </tr>
                        <tr>
                            <td class="cart-item-title">Seven By M.S.Dhoni W...</td>
                            <td>- 1 +</td>
                            <td>₹4,999</td>
                            <td><span class="remove-icon">×</span></td>
                        </tr>
                    </tbody>
                </table>
                <label for="state-product" class="continue-shopping">❮ Continue Shopping</label>
            </div>
            
            <div class="cart-right">
                <label class="section-label">Enter Coupon Code</label>
                <div class="coupon-section">
                    <input type="text" class="coupon-input" placeholder="COUPON CODE">
                    <button class="btn-coupon">Apply Coupon</button>
                </div>
                
                <div class="summary-row">
                    <span>Sub Total</span>
                    <span>₹4,700</span>
                </div>
                <div class="summary-row">
                    <span>Taxes (if applicable)</span>
                    <span>₹199</span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <span>0</span>
                </div>
                <div class="summary-row total">
                    <span>Total</span>
                    <span>₹4,999</span>
                </div>
                
                <label for="state-payment" class="btn-pay-now">Pay Now ₹4,999</label>
                <div class="trust-badges">
                    <span>🛡️ SECURE</span>
                    <span>⚡ Razorpay</span>
                </div>
            </div>
        </div>
    </div>


    <div id="view-payment" class="view-container">
        <div class="payment-container">
            <div class="payment-left">
                <h2>Checkout</h2>
                <div class="section-label">Contact Details</div>
                
                <div class="form-group">
                    <label>Email ID</label>
                    <input type="email" class="form-control" placeholder="john.doe@example.com">
                </div>
                
                <div class="section-label" style="margin-top: 30px;">Payment</div>
                <div class="payment-methods">
                    <div class="method-tab active">💳 Card</div>
                    <div class="method-tab">₿ Crypto</div>
                    <div class="method-tab">🏦 Bank</div>
                    <div class="method-tab">⋮</div>
                </div>
                
                <div class="form-group">
                    <label>Card Number</label>
                    <input type="number" class="form-control" placeholder="0000 0000 0000 0000">
                </div>
                
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label>Expiry</label>
                        <input type="number" class="form-control" placeholder="DD/MM/YY">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>CVC</label>
                        <input type="password" class="form-control" placeholder="•••">
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group" style="flex: 1;">
                        <label>Country</label>
                        <select class="form-control">
                            <option>India</option>
                            <option>United States</option>
                            <option>United Kingdom</option>
                            <option>Brazil</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>ZIP</label>
                        <input type="text" class="form-control" placeholder="123456">
                    </div>
                </div>
            </div>
            
            <div class="payment-right">
                <h3 style="margin-bottom: 25px; text-align: center; font-size: 22px;">Order Summary</h3>
                <label class="section-label">Enter Coupon Code</label>
                <div class="coupon-section">
                    <input type="text" class="coupon-input" placeholder="COUPON CODE">
                    <button class="btn-coupon">Apply Coupon</button>
                </div>
                
                <div class="summary-row">
                    <span>Sub Total</span>
                    <span>₹4,700</span>
                </div>
                <div class="summary-row">
                    <span>Taxes (if applicable)</span>
                    <span>₹199</span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <span>₹0</span>
                </div>
                <div class="summary-row total">
                    <span>Total</span>
                    <span>₹4,999</span>
                </div>
                
                <button class="btn-pay-now">Pay Now ₹4,999</button>
                <div class="trust-badges">
                    <span>🛡️ SECURE</span>
                    <span>⚡ Razorpay</span>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
